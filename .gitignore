# Rust
target/

# Strategy tables and simulation data (expensive, regenerated)
data/

# Outputs (cheap to regenerate)
outputs/

# Exception: treatise chart data is small, committed site source (NOT the
# expensive top-level data/). The broad `data/` rule above also matches
# `treatise/data/`, so re-include it explicitly. Keeping these in git means a
# fresh clone renders every chart without re-running the pipeline. Regenerate
# with `just regen-treatise-data`; verify completeness with `just check-treatise-data`.
!treatise/data/
!treatise/data/**

# Python virtualenvs
.venv/
analytics/.venv/

# Legacy C build artifacts
legacy/build/
legacy/cmake-build-debug/
legacy/compile_commands.json

# OS
.DS_Store

# Editors / IDE
*.swp
.idea/
.cache/
.claude/settings.local.json
.claude/plans/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ruff_cache/
.pytest_cache/

# RL package
research/rl/.venv/
research/rl/checkpoints/
research/rl/src/*.egg-info/

# Node (frontend + treatise)
node_modules/
frontend/dist/
treatise/sections/*.html

# Deploy build artifacts
deploy/build/

# Overhaul artifacts (historical)
.overhaul/

# Vite cache
.vite/

# Environment
.env
*.log
